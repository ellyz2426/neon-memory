<style>
  .set-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3;
    background-color: rgba(0, 0, 0, 0.9);
    border-color: #aa44ff;
    border-width: 0.15;
    border-radius: 1.5;
    gap: 1.2;
  }
  .set-title {
    font-size: 3;
    color: #aa44ff;
    font-weight: bold;
  }
  .set-section {
    font-size: 1.5;
    color: #ff00ff;
    font-weight: bold;
    padding-top: 0.3;
  }
  .set-row {
    display: flex;
    flex-direction: row;
    width: 90%;
    align-items: center;
    justify-content: space-between;
  }
  .set-label { font-size: 1.4; color: #aaaaaa; }
  .set-value { font-size: 1.4; color: #00ffff; font-weight: bold; }
  .set-btn {
    font-size: 1.4;
    color: #ffffff;
    background-color: rgba(170, 68, 255, 0.2);
    padding: 0.4;
    padding-left: 1;
    padding-right: 1;
    border-color: #aa44ff;
    border-width: 0.06;
    border-radius: 0.3;
    cursor: pointer;
  }
  .set-ctrl {
    display: flex;
    flex-direction: row;
    gap: 0.5;
    align-items: center;
  }
  .danger-btn {
    font-size: 1.3;
    color: #ff3344;
    background-color: rgba(255, 51, 68, 0.1);
    padding: 0.5;
    padding-left: 2;
    padding-right: 2;
    border-color: #ff3344;
    border-width: 0.06;
    border-radius: 0.3;
    cursor: pointer;
  }
  .back-btn {
    font-size: 1.6;
    color: #888888;
    background-color: rgba(128, 128, 128, 0.1);
    padding: 0.6;
    padding-left: 2;
    padding-right: 2;
    border-color: #555555;
    border-width: 0.06;
    border-radius: 0.4;
    cursor: pointer;
  }
</style>
<div class="set-panel">
  <span class="set-title">SETTINGS</span>
  <span class="set-section">AUDIO</span>
  <div class="set-row">
    <span class="set-label">Master Volume</span>
    <div class="set-ctrl">
      <div id="btn-master-down" class="set-btn" cursor="pointer">-</div>
      <span id="set-master" class="set-value">70%</span>
      <div id="btn-master-up" class="set-btn" cursor="pointer">+</div>
    </div>
  </div>
  <div class="set-row">
    <span class="set-label">SFX Volume</span>
    <div class="set-ctrl">
      <div id="btn-sfx-down" class="set-btn" cursor="pointer">-</div>
      <span id="set-sfx" class="set-value">80%</span>
      <div id="btn-sfx-up" class="set-btn" cursor="pointer">+</div>
    </div>
  </div>
  <div class="set-row">
    <span class="set-label">Music Volume</span>
    <div class="set-ctrl">
      <div id="btn-music-down" class="set-btn" cursor="pointer">-</div>
      <span id="set-music" class="set-value">50%</span>
      <div id="btn-music-up" class="set-btn" cursor="pointer">+</div>
    </div>
  </div>
  <span class="set-section">VISUAL</span>
  <div class="set-row">
    <span class="set-label">Arena Theme</span>
    <div class="set-ctrl">
      <div id="btn-theme-prev" class="set-btn" cursor="pointer">&lt;</div>
      <span id="set-theme" class="set-value">Neon Holodeck</span>
      <div id="btn-theme-next" class="set-btn" cursor="pointer">&gt;</div>
    </div>
  </div>
  <div class="set-row">
    <span class="set-label">Panel Markers</span>
    <div class="set-ctrl">
      <div id="btn-markers-toggle" class="set-btn" cursor="pointer">TOGGLE</div>
      <span id="set-markers" class="set-value">ON</span>
    </div>
  </div>
  <span class="set-section">DATA</span>
  <div id="btn-reset-data" class="danger-btn" cursor="pointer">RESET ALL DATA</div>
  <div id="btn-set-back" class="back-btn" cursor="pointer">BACK</div>
</div>
